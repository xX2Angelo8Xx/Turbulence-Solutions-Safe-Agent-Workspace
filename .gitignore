# Python bytecache
__pycache__/
*.pyc
*.pyo
*.pyd

# Eggs / packaging artifacts
.eggs/
*.egg-info/
dist/
build/

# PyInstaller generated spec files (auto-generated; source specs live in src/installer/)
*.spec
# launcher.spec is a manually maintained PyInstaller spec file — must remain tracked
!launcher.spec

# pytest cache
.pytest_cache/

# Stale pytest output captures (temp files — never commit)
pytest_*.txt

# Virtual environment (workspace-local — never commit)
.venv/
env/
venv/

# VS Code workspace-level settings (developer local)
.vscode/

# Retired CSV data files (migrated to JSONL in MNT-018; prevent re-staging)
docs/workpackages/workpackages.csv
docs/decisions/index.csv

# OS artifacts
.DS_Store
Thumbs.db
