#!/bin/sh
# Pre-commit hook — runs validate_workspace.py before every commit.
#
# This file lives in scripts/hooks/ (tracked by Git). Activate it by running:
#     .venv/Scripts/python scripts/install_hooks.py
#
# Or manually:
#     git config core.hooksPath scripts/hooks

# Resolve repo root (parent of scripts/hooks/)
REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

# Find the .venv Python interpreter (Windows first, then Unix)
if [ -x "$REPO_ROOT/.venv/Scripts/python.exe" ]; then
    PYTHON="$REPO_ROOT/.venv/Scripts/python.exe"
elif [ -x "$REPO_ROOT/.venv/bin/python" ]; then
    PYTHON="$REPO_ROOT/.venv/bin/python"
else
    echo "WARNING: .venv not found — running validation with system python3"
    PYTHON="python3"
fi

SCRIPT="$REPO_ROOT/scripts/validate_workspace.py"
if [ ! -f "$SCRIPT" ]; then
    echo "ERROR: $SCRIPT not found — aborting commit"
    exit 1
fi

echo "Running pre-commit validation..."
"$PYTHON" "$SCRIPT" --full
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "============================================================"
    echo "COMMIT BLOCKED: Validation errors found."
    echo "Fix all errors above, then try again."
    echo "============================================================"
    exit 1
fi

exit 0
