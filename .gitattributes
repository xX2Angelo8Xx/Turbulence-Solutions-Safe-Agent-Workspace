# Force shell scripts to use LF line endings on all platforms.
# Bash on Linux will fail with 'command not found' if scripts contain CRLF.
*.sh text eol=lf

# ts-python shim files - enforce correct line endings per platform
src/installer/shims/ts-python text eol=lf
src/installer/shims/ts-python.cmd text eol=crlf

# Template security files — enforce LF for cross-platform hash consistency
templates/agent-workbench/.github/hooks/scripts/*.py text eol=lf
templates/agent-workbench/.github/hooks/scripts/*.json text eol=lf
templates/agent-workbench/.github/hooks/*.json text eol=lf
templates/agent-workbench/.vscode/settings.json text eol=lf

# Template agent files — enforce LF so BOM/CRLF tests pass on all platforms (FIX-119)
templates/agent-workbench/.github/agents/*.md text eol=lf
templates/agent-workbench/.github/instructions/*.md text eol=lf
templates/agent-workbench/*.md text eol=lf
templates/agent-workbench/Project/*.md text eol=lf
