#!/bin/sh
CONFIG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/TurbulenceSolutions"
CONFIG="$CONFIG_DIR/python-path.txt"
DENY_MSG="Security gate cannot run -- Python runtime not found. All tool calls are blocked until the runtime is configured. Open the launcher Settings to fix."
if [ ! -f "$CONFIG" ]; then
    echo "ERROR: Python path configuration not found: $CONFIG" >&2
    printf '{"hookSpecificOutput": {"hookEventName": "PreToolUse", "permissionDecision": "deny", "permissionDecisionReason": "%s"}}\n' "$DENY_MSG"
    exit 0
fi
PYTHON_PATH=$(cat "$CONFIG")
if [ ! -x "$PYTHON_PATH" ]; then
    echo "ERROR: Python executable not found or not executable: $PYTHON_PATH" >&2
    printf '{"hookSpecificOutput": {"hookEventName": "PreToolUse", "permissionDecision": "deny", "permissionDecisionReason": "%s"}}\n' "$DENY_MSG"
    exit 0
fi
exec "$PYTHON_PATH" "$@"
